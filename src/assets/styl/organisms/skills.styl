.skills-container
	width 100%
	padding 0
	margin 1% auto
	text-align center
	
	.skills-border
		width 80%
		margin 1% auto
		border 4px solid white
		padding 1%
		@media screen and (min-width: 820px)
			width 25%
			clear none
			display inline-block
			padding 0.5%
			
	
	.skills-box
		background-color white
		list-style none
		padding 0.5em
		margin auto
		width 100%
		min-height 150px
		clear both
		@media screen and (min-width: 820px)
			width 100%
			min-height 190px
			clear none
			float left
		
		p:nth-of-type(1)
			text-align center
			vertical-align middle
			text-transform uppercase
			font-weight bold
			font-size 15px
			font-family $default-font
			color $cyan
		p:nth-of-type(2)
			text-align center
			font-family $second-font
			font-size 14px
			color $default-color
			
		i 
			width 100%
			float left
			text-align center
			padding-top 3%
			
	.skills-border:nth-of-type(1)
		.skills-box
			color $orange
	.skills-border:nth-of-type(2)
		.skills-box
			color $blue
	.skills-border:nth-of-type(3)
		.skills-box
			color $pink
	
.skills-list
	width 100%
	margin 0 auto
	float left
	clear both
	
	ul
		width 50%
		float left
		margin 0 auto
		padding 2% 
		
	ul li
		margin 0.5em auto
		text-align center
		list-style none
		.skills-level
			padding 0.5em
			list-style none
			background-color rgba(255,255,255,0.6)
			border-radius 3px
			p
				font-family $default-font
				color $default-color
			i 
				color $green
			
			
			
		
	 		