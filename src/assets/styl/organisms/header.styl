header 
	width 100%
	
.header-bg
	height 100%
	background-repeat repeat	
	padding 15px
	@media screen and (min-width: 1200px)
		padding 40px
		

.header-container
	background-color rgba(255,255,255,1)
	width 94%
	height 90vh
	text-align center
	clear both
	margin 2% auto
	padding-top 80px
	
	h2 
		width 65%
		font-family $third-font
		font-size 2.85em
		font-weight normal
		text-align center
		margin 0 auto
		color $blue
		text-transform uppercase
		@media screen and (min-width: 500px)
				font-size 5em
		p:nth-of-type(1)
			color $pink
			font-size 0.5em
			margin-top -2%
			margin-bottom -2%
		p:nth-of-type(2)
			letter-spacing 1px
			color $cyan
			font-size 0.8em
			margin-top -2%
			margin-bottom -2%
			
	
.header-border-right
	background-color white
	width 3px
	height 100%
	position fixed
	top 0
	right 4px
	bottom: 0
	@media screen and (min-width: 1200px)
		right 10px
		width 5px
	
.header-border-left
	background-color white
	float left
	width 3px
	height 100%
	position fixed
	top 0
	left 4px
	bottom: 0
	@media screen and (min-width: 1200px)
		left 10px
		width 5px
	


	

	
	
