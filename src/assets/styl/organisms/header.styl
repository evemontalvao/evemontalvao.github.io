header 
	width 100%
	min-height 100vh
	background-color white
	margin-top 0
	padding-top 1%
		

.header-container
	background-image url('../img/header.jpg')
	width 98%
	height 98vh
	text-align center
	clear both
	margin 0 auto
	padding-top 80px
	
	h2 
		width 65%
		font-family $fourth-font
		font-size 2.85em
		font-weight normal
		text-align center
		margin 0 auto
		color $blue
		text-transform uppercase
		@media screen and (min-width: 500px)
				font-size 5em
		p:nth-of-type(1)
			color $pink
			font-size 0.5em
			margin-top -2%
			margin-bottom -2%
		p:nth-of-type(2)
			letter-spacing 1px
			color $cyan
			font-size 0.8em
			margin-top -2%
			margin-bottom -2%
			
	
.header-border-right
	background-color white
	width 3px
	height 100%
	position fixed
	top 0
	right 4px
	bottom: 0
	@media screen and (min-width: 1200px)
		right 10px
		width 5px
	
.header-border-left
	background-color white
	float left
	width 3px
	height 100%
	position fixed
	top 0
	left 4px
	bottom: 0
	@media screen and (min-width: 1200px)
		left 10px
		width 5px
	


	

	
	
