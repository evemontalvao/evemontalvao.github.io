.sobre
	margin 0 auto
	clear both
	width 100%
	min-height 50vh
	background-image url('../img/sobre2.jpg')
	background-size cover
	background-attachment fixed
	padding 1%
	@media screen and (min-width: 800px)
		background-position -300px
	@media screen and (min-width: 900px)
		background-position -200px
	@media screen and (min-width: 1000px)
		background-position -100px
	@media screen and (min-width: 1200px)
		background-position 0
	
	p
		font-size $default-size
		color white
		text-align justify
		word-spacing -2px
		font-family $default-font
		letter-spacing 1px
		margin-top 0
		padding 6%
		@media screen and (min-width: 800px)
			width 70%
		
	
.sobre-logo-container
	width 100px
	margin-top 1em
	margin-left auto
	margin-right auto
	letter-spacing 1px
	font-weight normal
	text-align center
	@media screen and (min-width: 800px)
		display none
	
	.sobre-logo
		width 50px
	
.foto-sobre
	display block
	width 200px
	margin 0 auto

.github
	margin 0 auto
	min-height 30vh
	background-color rgba(255,255,255,0.7)
	padding-top 3em
	p
		margin 0
		text-align center
		font-family $default-font
		color $default-color
			
		
	p.git
		margin 1em auto
		padding 1em
		background $pink
		border-radius 3px
		width 200px
		&:hover
			background-color $blue
		a 
			color white
			text-decoration none
			display block
			
		