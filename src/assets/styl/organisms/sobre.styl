.sobre
	margin 1% auto
	clear both
	width 90%
	min-height 50vh
	background-image url('../img/sobre2.jpg')
	background-size cover
	background-attachment fixed
	padding 1%
	@media screen and (min-width: 800px)
		background-position -300px
	@media screen and (min-width: 900px)
		background-position -200px
	@media screen and (min-width: 1000px)
		background-position -100px
	@media screen and (min-width: 1200px)
		background-position 0
	
	p
		font-size $default-size
		color white
		text-align justify
		word-spacing -2px
		font-family $default-font
		letter-spacing 1px
		margin-top 0
		padding 6%
		@media screen and (min-width: 800px)
			width 70%
		
	
.sobre-logo-container
	width 100px
	margin-top 1em
	margin-left auto
	margin-right auto
	letter-spacing 1px
	font-weight normal
	text-align center
	@media screen and (min-width: 800px)
		display none
	
	.sobre-logo
		width 50px
	
.foto-sobre
	display block
	width 200px
	margin 0 auto
	